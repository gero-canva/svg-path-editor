{
  "name": "svg-path-editor",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "build-prod": "ng build --configuration production --base-href=/svg-path-editor/",
    "test": "ng test",
    "lint": "ng lint",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "install-bin": "mkdir -p \"$HOME/bin\" && test -f src-tauri/target/release/svg-path-editor && install -m 755 src-tauri/target/release/svg-path-editor \"$HOME/bin/svg-path-editor\"",
    "build-lib": "rimraf ./src/lib/dist &&  tsdown"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.21",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.21",
    "@angular/compiler": "^20.3.21",
    "@angular/core": "^20.3.21",
    "@angular/forms": "^20.3.21",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.21",
    "@angular/platform-browser-dynamic": "^20.3.21",
    "@angular/router": "^20.3.21",
    "@angular/service-worker": "^20.3.21",
    "@tauri-apps/api": "^2.11.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.25",
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/cli": "~20.3.25",
    "@angular/compiler-cli": "^20.3.21",
    "@tauri-apps/cli": "^2.11.1",
    "@types/jasmine": "~4.3.0",
    "@typescript-eslint/eslint-plugin": "7.4.0",
    "@typescript-eslint/parser": "7.4.0",
    "eslint": "^8.57.0",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "rimraf": "^6.0.1",
    "tsdown": "^0.15.1",
    "typescript": "~5.8.3"
  }
}
